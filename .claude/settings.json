{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "bun run fmt:check && bun run lint && bun test",
            "timeout": 60,
            "statusMessage": "fmt:check · lint · test"
          }
        ]
      }
    ]
  }
}