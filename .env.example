# Choose the platform adapter: "discord" (default) or "telegram"
ADAPTER=discord

# --- Discord ---
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
DISCORD_ANNOUNCEMENT_CHANNEL_ID=
DISCORD_FORUM_CHANNEL_ID=

# --- Telegram ---
# Requires a supergroup with Topics enabled.
TELEGRAM_TOKEN=
TELEGRAM_GROUP_CHAT_ID=

# --- Scheduler ---
# Timezone used for reminder windows (day-before and hour-before).
# Must match the timezone of your group. See https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Europe/Paris

# --- Database ---
# SQLite (default — no extra setup needed)
DATABASE_PATH=./data/group-ride.db

# PostgreSQL — if set, DATABASE_PATH is ignored and PostgreSQL is used instead
# DATABASE_URL=postgres://user:password@localhost:5432/group_ride
