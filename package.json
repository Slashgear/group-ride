{
  "name": "group-ride",
  "version": "0.3.0",
  "description": "Discord bot to organise group cycling rides",
  "module": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "test": "bun test",
    "fmt": "oxfmt src tests",
    "fmt:check": "oxfmt --check src tests",
    "lint": "oxlint src",
    "lint:fix": "oxlint --fix src",
    "typecheck": "tsc --noEmit",
    "release": "git tag -a \"v$(node -p \"require('./package.json').version\")\" -m \"Release v$(node -p \"require('./package.json').version\")\" && git push --tags"
  },
  "dependencies": {
    "@grammyjs/conversations": "^2.1.1",
    "discord.js": "^14.26.4",
    "grammy": "^1.43.0",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "oxlint-tsgolint": "^0.23.0",
    "pino-pretty": "^13.1.3"
  }
}