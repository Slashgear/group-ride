{
  "name": "group-ride",
  "version": "1.12.0",
  "description": "Discord bot to organise group cycling rides",
  "workspaces": [
    "website"
  ],
  "type": "module",
  "module": "src/index.ts",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "test": "bun test",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint src tests",
    "lint:fix": "oxlint --fix src tests",
    "typecheck": "bunx tsc --noEmit",
    "website": "bun run --cwd website dev",
    "release": "git tag -a \"v$(node -p \"require('./package.json').version\")\" -m \"Release v$(node -p \"require('./package.json').version\")\" && git push --tags"
  },
  "dependencies": {
    "@grammyjs/conversations": "^2.1.1",
    "discord.js": "^14.27.0",
    "fast-xml-parser": "^5.10.1",
    "gpxsnap": "^1.1.0",
    "grammy": "^1.45.1",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "^0.25.0",
    "pino-pretty": "^13.1.3"
  },
  "overrides": {
    "undici": "^6.27.0",
    "ws": "^8.21.1"
  }
}
