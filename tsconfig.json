{
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleDetection": "force",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "types": ["bun"],
    "paths": {
      "@domain/*": ["./src/domain/*"],
      "@services/*": ["./src/services/*"],
      "@adapters/*": ["./src/adapters/*"]
    }
  },
  "include": ["src", "tests"]
}
